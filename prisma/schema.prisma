generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(cuid())
  username     String    @unique
  name      String
  password  String
  createdAt DateTime  @default(now())
  articles  Article[]
  events    Event[]
}

enum ArticleCategory {
  GEOBIOLOGIE
  MAGNETISME
  THERAPIES_ENERGETIQUES
  SOURCELLERIE
  SYLVOTHERAPIE
  RADIESTHESIE
  FORMATIONS
  ACTUALITE
}

model Article {
  id         String            @id @default(cuid())
  slug       String            @unique
  title      String
  excerpt    String
  content    String            @db.Text
  coverImage String?
  categories ArticleCategory[]
  published  Boolean           @default(true)
  authorId   String
  author     Admin             @relation(fields: [authorId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([published, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  date        DateTime
  endDate     DateTime?
  title       String
  description String    @db.Text
  category    String
  authorId    String
  author      Admin     @relation(fields: [authorId], references: [id])
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, date])
}
